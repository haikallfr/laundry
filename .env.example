DATABASE_URL="postgresql://postgres:postgres@localhost:5432/laundry_pos?schema=public"
JWT_SECRET="ganti-dengan-secret-minimal-32-karakter"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Legacy JSON store. Biarkan aktif saat deploy pertama agar data lama di app_store
# otomatis dipindahkan ke tabel Prisma/Postgres jika tabel users masih kosong.
# Use a server-only key here. Do not prefix the service role key with NEXT_PUBLIC_.
SUPABASE_URL="https://project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="isi-service-role-key"
# Kalau tidak punya service role key di environment ini, isi SUPABASE_ANON_KEY sebagai fallback server-side.
SUPABASE_ANON_KEY="isi-anon-key"
SUPABASE_STORE_TABLE="app_store"
APP_STORE_KEY="default"
